<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AirPlayReceiver.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscapeAccelerator"/>
            <KeyboardAccelerator Key="Enter" Modifiers="Menu" Invoked="OnFullscreenAccelerator"/>
        </Grid.KeyboardAccelerators>

        <!-- Toolbar -->
        <Grid x:Name="Toolbar" Grid.Row="0" Padding="20,14"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Ellipse x:Name="StatusIndicator" Grid.Column="0"
                     Width="18" Height="18" Fill="Gray"
                     VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Grid.Column="1"
                       Margin="12,0,0,0" FontSize="16" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <Button x:Name="FullscreenButton" Grid.Column="3"
                    Click="FullscreenButton_Click"
                    Width="40" Height="40" Padding="0"
                    Margin="0,0,6,0"
                    Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Vollbild (Alt+Enter)">
                <SymbolIcon x:Name="FullscreenIcon" Symbol="FullScreen"/>
            </Button>

            <Button x:Name="MoreButton" Grid.Column="4"
                    Width="40" Height="40" Padding="0"
                    Margin="0,0,12,0"
                    Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Mehr">
                <SymbolIcon Symbol="More"/>
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="MenuSettings" Text="Einstellungen…" Click="MenuSettings_Click">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="Setting"/></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuLog" Text="Log öffnen" Click="MenuLog_Click">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="Document"/></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem x:Name="MenuAbout" Text="Über AirPlay-Empfänger" Click="MenuAbout_Click"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <Button x:Name="ToggleButton" Grid.Column="5"
                    Click="ToggleButton_Click"
                    Style="{ThemeResource AccentButtonStyle}" MinWidth="170">
                <TextBlock x:Name="ToggleButtonText" FontSize="14"/>
            </Button>
        </Grid>

        <!-- Video-Host -->
        <Grid Grid.Row="1" x:Name="VideoHost" Background="#0A0A0A"
              SizeChanged="VideoHost_SizeChanged">
            <StackPanel x:Name="IdleHint"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="10" MaxWidth="420">
                <TextBlock x:Name="DetailText" FontSize="14"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center"
                           HorizontalTextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
